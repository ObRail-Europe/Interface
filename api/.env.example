# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_USER=obrail
PG_PASSWORD=obrail
PG_HOST=db
PG_PORT=5432
PG_DB=obrail

# ── Sécurité API (endpoints POST /import/*) ───────────────────────────────────

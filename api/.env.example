# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=obrail
POSTGRES_PASSWORD=obrail
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=obrail

# ── Sécurité API (endpoints POST /import/*) ───────────────────────────────────
# Changer impérativement en production !
API_KEY=changeme-obrail-secret

# ── Debug SQL (mettre true pour voir les requêtes dans les logs) ──────────────
DB_ECHO=false

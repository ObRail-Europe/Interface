# Copier ce fichier en `.env` puis ajuster si besoin :  cp .env.example .env

# Identifiants PostgreSQL - utilisés par les services `db` et `api` (docker-compose).
POSTGRES_USER=obrail
POSTGRES_PASSWORD=obrail
POSTGRES_DB=obrail

# Supervision (V9) - niveau de log applicatif et URL Grafana embarquée côté navigateur.
LOG_LEVEL=INFO
GRAFANA_URL=http://localhost:3000
